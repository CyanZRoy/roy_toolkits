#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
    cat <<'EOF'
rtoolkit - personal Linux server toolkit

Usage:
  rtoolkit
  rtoolkit list
  rtoolkit <command> [options]
  rtoolkit help <command>

Available commands:
  merge-fastq    Merge original and resequenced FASTQ files.

Examples:
  rtoolkit list
  rtoolkit merge-fastq -h
EOF
}

list_tools() {
    cat <<'EOF'
Available rtoolkit commands:
  merge-fastq    Merge original and resequenced FASTQ files.
EOF
}

command_help() {
    local command_name="${1:-}"
    case "${command_name}" in
        merge-fastq)
            exec "${ROOT_DIR}/tools/merge-fastq/bin/merge-fastq" -h
            ;;
        ""|-h|--help)
            usage
            ;;
        *)
            printf 'Unknown command: %s\n\n' "${command_name}" >&2
            list_tools >&2
            exit 2
            ;;
    esac
}

main() {
    local command_name="${1:-}"

    case "${command_name}" in
        ""|-h|--help)
            usage
            ;;
        list)
            list_tools
            ;;
        help)
            shift || true
            command_help "${1:-}"
            ;;
        merge-fastq)
            shift
            exec "${ROOT_DIR}/tools/merge-fastq/bin/merge-fastq" "$@"
            ;;
        *)
            printf 'Unknown command: %s\n\n' "${command_name}" >&2
            list_tools >&2
            exit 2
            ;;
    esac
}

main "$@"
